# =============================================================================
# YŪGEN — environment variables
# Copy this file to `.env.local` and fill in real values.
# Every var here is PUBLIC (NEXT_PUBLIC_*) because the site is a static export
# and these services are designed for safe client-side use.
# The site runs fine WITHOUT these (forms simulate success in "dev mode"),
# but email delivery + spam protection require them in production.
# =============================================================================

# ----- EmailJS (contact + reservation delivery) -----------------------------
# Create a free account at https://www.emailjs.com, add an email service and
# two templates (one for contact, one for reservations).
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
NEXT_PUBLIC_EMAILJS_CONTACT_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_RESERVATION_TEMPLATE_ID=

# ----- Cloudflare Turnstile (spam protection) -------------------------------
# Create a free widget at https://dash.cloudflare.com/?to=/:account/turnstile
# Paste the SITE key here (the SECRET key is only needed if you add a
# server-side verification Worker — see README "Security").
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
